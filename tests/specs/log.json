[
  {
    "name": "/log requires an active trip",
    "steps": [
      {
        "send": { "text": "/log" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "You don't have an active trip yet. Create one first!" } }
        ]
      }
    ]
  },
  {
    "name": "full create then log expense flow",
    "steps": [
      {
        "send": { "text": "/create" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What's the name of your trip?" } }
        ]
      },
      {
        "send": { "text": "Expense Test Trip" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Got it! What currency for \"Expense Test Trip\"? (default: USD)" } }
        ]
      },
      {
        "send": { "callback": "trip:create:currency:USD" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage", "payload": { "text": "✅ Trip \"Expense Test Trip\" created!\nCurrency: USD\nYou're the organizer." } }
        ]
      },
      {
        "send": { "text": "/add" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Send me the user ID or username of the person to add:" } }
        ]
      },
      {
        "send": { "text": "77777" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "✅ Added to the trip!" } }
        ]
      },
      {
        "send": { "text": "/log" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "How much did you spend?" } }
        ]
      },
      {
        "send": { "text": "60" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What was it for?" } }
        ]
      },
      {
        "send": { "text": "Dinner" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Who paid?" } }
        ]
      },
      {
        "send": { "callback": "trip:log:payer:1" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage", "payload": { "text": "Who should split this? (comma-separated IDs, or \"all\" for everyone)\nMembers: You, User 77777" } }
        ]
      },
      {
        "send": { "callback": "trip:log:bene:all" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage", "payload": { "text": "✅ Logged: Dinner — USD 60.00\nSplit among 2 people (USD 30.00 each)" } }
        ]
      }
    ]
  }
]
