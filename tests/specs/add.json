[
  {
    "name": "/add requires an active trip",
    "steps": [
      {
        "send": { "text": "/add" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "You don't have an active trip yet. Create one first!" } }
        ]
      }
    ]
  },
  {
    "name": "full create then add member flow",
    "steps": [
      {
        "send": { "text": "/create" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What's the name of your trip?" } }
        ]
      },
      {
        "send": { "text": "Add Test Trip" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Got it! What currency for \"Add Test Trip\"? (default: USD)" } }
        ]
      },
      {
        "send": { "callback": "trip:create:currency:USD" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage", "payload": { "text": "✅ Trip \"Add Test Trip\" created!\nCurrency: USD\nYou're the organizer." } }
        ]
      },
      {
        "send": { "text": "/add" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Send me the user ID or username of the person to add:" } }
        ]
      },
      {
        "send": { "text": "99999" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "✅ Added to the trip!" } }
        ]
      }
    ]
  }
]
